#
# Reserved pin file for Perfetto recording-side tools used by `smp capture`.
# SmartPerfetto does not download these at runtime. If an approved release flow
# later commits tracebox prebuilts under backend/prebuilts/perfetto-recording-tools,
# the binaries must match the version and SHA256 values recorded here.

PERFETTO_RECORDING_TOOLS_VERSION=v54.0
PERFETTO_RECORDING_TOOLS_URL_BASE=https://commondatastorage.googleapis.com/perfetto-luci-artifacts

# SHA256 values are intentionally left empty until approved tracebox artifacts
# are committed. Do not infer approval from Google's SDK/Platform-Tools pages;
# ADB and SDK artifacts have their own license acceptance and redistribution
# constraints.
PERFETTO_TRACEBOX_SHA256_LINUX_X64=
PERFETTO_TRACEBOX_SHA256_LINUX_ARM64=
PERFETTO_TRACEBOX_SHA256_DARWIN_ARM64=
PERFETTO_TRACEBOX_SHA256_DARWIN_X64=
PERFETTO_TRACEBOX_SHA256_ANDROID_ARM64=
PERFETTO_TRACEBOX_SHA256_ANDROID_ARM=
PERFETTO_TRACEBOX_SHA256_ANDROID_X64=
PERFETTO_TRACEBOX_SHA256_ANDROID_X86=
